# Server
PORT=8080
NODE_ENV=development

# PostgreSQL (Prisma)
# Docker: postgresql://user:pass@postgres:5432/dbname
# Local:  postgresql://user:pass@localhost:5432/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
DB_USER=user
DB_PASS=password
DB_NAME=dbname

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# JWT
ACCESS_SECRET=your-secret-key
ACCESS_EXPIRES=15m
REFRESH_TTL=5184000

# OAuth 2.0
# Google: https://console.cloud.google.com/ → Credentials → OAuth 2.0 Client IDs
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# GitHub: https://github.com/settings/developers → OAuth Apps
GITHUB_OAUTH_CLIENT_ID=your-github-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-github-client-secret

# Base URL for OAuth callbacks (without trailing slash)
# e.g. http://localhost:8080/api/v1/auth/oauth/callback
PROVIDER_OAUTH_REDIRECT_URI=http://localhost:8080/api/v1/auth/oauth/callback
